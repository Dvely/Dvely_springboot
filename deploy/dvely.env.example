# /etc/dvely/dvely.env 로 복사해 값을 채운다.
#   sudo install -m 0640 -o root -g dvely dvely.env.example /etc/dvely/dvely.env
#
# systemd EnvironmentFile은 KEY=VALUE 한 줄씩만 받는다.
# 따옴표는 값의 일부로 들어가므로 감싸지 않는다. 여러 줄 값도 넣을 수 없다.

# --- 필수: 없으면 기동 실패 ---

# prod 프로파일은 ddl-auto=validate 라서 Flyway 마이그레이션이 끝난 스키마여야 한다.
DB_URL=jdbc:mysql://localhost:3306/dvely?useSSL=false&serverTimezone=Asia/Seoul
DB_USERNAME=dvely
DB_PASSWORD=

# 클라우드 자격증명 암복호화 키.
ENCRYPT_SECRET=

# 서비스 JWT 서명 키 (HS256). 충분히 긴 랜덤 문자열.
JWT_SECRET=

# GitHub OAuth App — 로그인용
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://api.qeploy.com/api/v1/auth/github/callback

# GitHub App — 레포 접근용
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_INSTALLATION_REDIRECT_URI=https://api.qeploy.com/api/v1/auth/github/app/callback
# PEM 전문은 여러 줄이라 이 파일에 넣을 수 없다.
# GithubAppClient는 값이 "-----BEGIN"으로 시작하지 않으면 파일 경로로 읽으므로 경로를 준다.
#   sudo install -m 0640 -o root -g dvely github-app.pem /etc/dvely/github-app.pem
GITHUB_APP_PRIVATE_KEY=/etc/dvely/github-app.pem

# --- 선택: 비우면 코드의 기본값을 쓴다 ---

# 둘 중 쓰는 provider의 키만 채우면 된다.
QEPLOY_AI_ANTHROPIC_API_KEY=
QEPLOY_AI_OPENAI_API_KEY=

# 프론트엔드 오리진. 비우면 CORS가 모두 차단되므로 사실상 필요하다.
QEPLOY_CORS_ALLOWED_ORIGINS=https://qeploy.com
FRONTEND_REDIRECT_URL=https://qeploy.com
